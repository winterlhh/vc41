{
  "kind": "singleType",
  "collectionName": "profiles",
  "info": {
    "singularName": "profile",
    "pluralName": "profiles",
    "displayName": "Profile",
    "description": "Site owner profile information"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "bio": {
      "type": "text"
    },
    "avatar": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "avatarAlt": {
      "type": "string"
    },
    "backgroundSrc": {
      "type": "string"
    },
    "backgroundAlt": {
      "type": "string"
    },
    "likeLabel": {
      "type": "string",
      "default": "Like"
    },
    "likeCount": {
      "type": "integer",
      "default": 0
    },
    "socialLinks": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::social-link.social-link"
    }
  }
}
